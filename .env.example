# Brihaspati Configuration
# Copy this file to .env and adjust values

# Application
APP_NAME=Brihaspati
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-this-to-a-random-secret-key

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# RAG / Vector Store
VECTOR_STORE_PATH=./vector_db
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=4

# Memory
MEMORY_TYPE=json  # json | redis
MEMORY_TTL_HOURS=24
MAX_CONVERSATION_HISTORY=50

# Redis (optional, for production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Code Execution
CODE_EXECUTION_ENABLED=false
CODE_EXECUTION_TIMEOUT=10
CODE_EXECUTION_MAX_OUTPUT_LENGTH=4096

# Session
SESSION_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=*

# Logging
LOG_FILE=logs/brihaspati.log
